# Ensure shell scripts always use LF line endings in the repo and on checkout.
# Windows git (core.autocrlf=true) would otherwise convert them to CRLF,
# causing "bad interpreter: /bin/sh^M" errors when run inside Linux containers.
*.sh text eol=lf

# Standard text files — normalize on commit, use platform endings on checkout
*.py  text eol=lf
*.ts  text eol=lf
*.tsx text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md  text eol=lf
*.txt text eol=lf
