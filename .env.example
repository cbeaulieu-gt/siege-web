# =============================================================================
# TIER 1 — Required for any run (Docker or native dev)
# =============================================================================

# PostgreSQL connection string.
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/siege

# Backend environment; must be one of: development, production.
ENVIRONMENT=development

# Demo/dev mode: disables OAuth login so you can use the app without Discord.
# Set to false (or remove) for any real deployment.
AUTH_DISABLED=true

# HS256 signing key for session JWTs.
# Required when AUTH_DISABLED=false — the backend refuses to start without it.
# Generate a secure value with:  python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=changeme-use-a-long-random-string-in-production

# =============================================================================
# TIER 2 — Required only when running with real Discord OAuth (AUTH_DISABLED=false)
# =============================================================================

# Discord OAuth2 — register your app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-app-client-id
DISCORD_CLIENT_SECRET=your-discord-app-client-secret
DISCORD_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Discord bot token (from the Bot section of your dev portal application)
DISCORD_TOKEN=your-discord-bot-token-here

# Your Discord server (guild) ID
DISCORD_GUILD_ID=your-guild-id-here

# Channel names where the bot posts siege assignments and images
DISCORD_SIEGE_CHANNEL=clan-siege-assignments
DISCORD_SIEGE_IMAGES_CHANNEL=clan-siege-assignment-images

# Shared secret between backend and bot sidecar
DISCORD_BOT_API_URL=http://bot:8001
DISCORD_BOT_API_KEY=changeme
BOT_API_KEY=changeme

# Bearer token for bot→backend calls; leave empty to disable the check in dev.
BOT_SERVICE_TOKEN=

# Discord role name required to log in (exact match, case-sensitive).
# Members in the guild but lacking this role receive an insufficient_role error.
DISCORD_REQUIRED_ROLE=Clan Deputies

# =============================================================================
# TIER 3 — Azure / deploy-only (not needed for local dev)
# =============================================================================

# Public-facing canonical URL for this deployment.
# Used in <link rel="canonical"> and og:url meta tags.
# Set to your domain when self-hosting (e.g. https://siege.example.com/).
VITE_PUBLIC_URL=https://siege.higgsbp.com/

# Path used by the one-time Excel import CLI script
IMPORT_EXCEL_PATH=C:/path/to/siege/excel/files

# Azure Application Insights (optional; telemetry SDK is a no-op when unset)
# APPLICATIONINSIGHTS_CONNECTION_STRING=
